# Huly Self-Hosted Environment Configuration
# Copy to .env and edit. Only DATABASE_URL is required for a working setup.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

HULY_VERSION=v0.7.426
DOCKER_NAME=huly
HOST_ADDRESS=localhost:8080
SECURE=
HTTP_PORT=8080
HTTP_BIND=
TITLE=Huly
DEFAULT_LANGUAGE=en
LAST_NAME_FIRST=true
SECRET=

# PostgreSQL — the one thing you must get right.
# Point to your external Postgres or use the bundled Docker postgres.
# For external: DATABASE_URL=postgres://user:pass@your-host:5432/huly
# For Docker postgres: set POSTGRES_PASSWORD below, DATABASE_URL is auto-configured.
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://selfhost:${POSTGRES_PASSWORD}@postgres:5432/huly

# Redpanda
REDPANDA_ADMIN_USER=superadmin
REDPANDA_ADMIN_PWD=

# Volume paths — leave empty for Docker named volumes
VOLUME_ELASTIC_PATH=
VOLUME_FILES_PATH=
VOLUME_REDPANDA_PATH=

# =============================================================================
# optional: Google OAuth Login (Sign in with Google)
# =============================================================================
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI: http://localhost:8080/auth/openid/callback
# OPENID_CLIENT_ID=
# OPENID_CLIENT_SECRET=
# OPENID_ISSUER=https://accounts.google.com

# =============================================================================
# optional: Web Push Notifications
# =============================================================================
PUSH_PUBLIC_KEY=
PUSH_PRIVATE_KEY=

# =============================================================================
# optional: Email (SMTP or SES)
# =============================================================================
MAIL_SOURCE=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SES_ACCESS_KEY=
# SES_SECRET_KEY=
# SES_REGION=

# =============================================================================
# optional: Audio/Video Calls (requires LiveKit)
# =============================================================================
# LIVEKIT_HOST=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# =============================================================================
# optional: AI Chatbot (requires MongoDB)
# =============================================================================
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# AIBOT_PASSWORD=

# =============================================================================
# optional: Google Calendar (requires MongoDB)
# =============================================================================
GOOGLE_CALENDAR_CREDENTIALS=

# =============================================================================
# optional: GitHub Integration
# =============================================================================
# GITHUB_APPID=
# GITHUB_APP_SLUG=
# GITHUB_CLIENTID=
# GITHUB_CLIENT_SECRET=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=

# =============================================================================
# optional: Telegram Bot
# =============================================================================
# TELEGRAM_BOT_TOKEN=
