# =============================================================================
# Huly Self-Hosted Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments. Remove # to enable optional settings.

# -----------------------------------------------------------------------------
# Core: General
# -----------------------------------------------------------------------------

HULY_VERSION=v0.6.501
DOCKER_NAME=huly

# The address of the host or server from which you will access your Huly instance.
# This can be a domain name (e.g., huly.example.com) or an IP address (e.g., 192.168.1.1).
HOST_ADDRESS=localhost:8080

# Set this variable to 'true' to enable SSL (HTTPS/WSS).
# Leave it empty to use non-SSL (HTTP/WS).
SECURE=

# Specify the IP address to bind to; leave blank to bind to all interfaces (0.0.0.0).
# Do not use IP:PORT format in HTTP_BIND or HTTP_PORT.
HTTP_PORT=8080
HTTP_BIND=

# Huly specific variables
TITLE=Huly Self Host
DEFAULT_LANGUAGE=en
LAST_NAME_FIRST=true

# Auto-generated secret. Run with --secret to regenerate.
SECRET=

# -----------------------------------------------------------------------------
# Core: CockroachDB
# -----------------------------------------------------------------------------

CR_DATABASE=defaultdb
CR_USERNAME=selfhost
CR_USER_PASSWORD=

# -----------------------------------------------------------------------------
# Core: Redpanda
# -----------------------------------------------------------------------------

REDPANDA_ADMIN_USER=superadmin
REDPANDA_ADMIN_PWD=

# -----------------------------------------------------------------------------
# Core: Docker Volume Paths
# -----------------------------------------------------------------------------
# Leave empty to use default Docker named volumes.

VOLUME_ELASTIC_PATH=
VOLUME_FILES_PATH=
VOLUME_CR_DATA_PATH=
VOLUME_CR_CERTS_PATH=
VOLUME_REDPANDA_PATH=

# =============================================================================
# optional: Web Push Notifications (notification service)
# =============================================================================

PUSH_PUBLIC_KEY=
PUSH_PRIVATE_KEY=

# =============================================================================
# optional: Email Service (mail service — SMTP or Amazon SES, not both)
# =============================================================================

MAIL_SOURCE=noreply@example.com

# SMTP configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Amazon SES configuration (alternative to SMTP)
# SES_ACCESS_KEY=
# SES_SECRET_KEY=
# SES_REGION=

# =============================================================================
# optional: Audio/Video Calls (love service — requires LiveKit)
# =============================================================================

LIVEKIT_HOST=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# =============================================================================
# optional: AI Chatbot (aibot service — requires MongoDB)
# =============================================================================

OPENAI_API_KEY=
OPENAI_BASE_URL=
AIBOT_PASSWORD=

# Model overrides (optional, defaults to gpt-4o-mini)
# OPENAI_MODEL=
# OPENAI_TRANSLATE_MODEL=
# OPENAI_SUMMARY_MODEL=

# =============================================================================
# optional: Google Calendar (calendar service — requires MongoDB)
# =============================================================================

# JSON string of Google OAuth credentials from Google Cloud Console
GOOGLE_CALENDAR_CREDENTIALS=

# =============================================================================
# optional: GitHub Integration (github service)
# =============================================================================

GITHUB_APPID=
GITHUB_APP_SLUG=
GITHUB_CLIENTID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# =============================================================================
# optional: Telegram Bot (telegram-bot service)
# =============================================================================

TELEGRAM_BOT_TOKEN=
